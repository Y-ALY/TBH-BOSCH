# ── OpenRouter API Key ──────────────────────────────────────────────────────────
# Required for AI-powered document classification (src/ai_parser.py).
# Get your key at https://openrouter.ai/keys
# WARNING: Do not commit real keys. This file is a template only.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Optional: Override the default OpenRouter model ─────────────────────────────
# Default: anthropic/claude-sonnet-4
# OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ── Database URL ────────────────────────────────────────────────────────────────
# Reads from DATABASE_URL env var at startup (database.py).
# Fallback (if not set): sqlite:///./bosch_gdpr.db  (local demo only).
# Render sets this automatically when a PostgreSQL database is attached.
# Example:
# DATABASE_URL=postgresql://user:password@host:5432/bosch_gdpr

# ── Demo Scan Root ──────────────────────────────────────────────────────────────
# Directory to scan for demo data. Default: ./demo_drive_rich
# SCAN_ROOT=./demo_drive_rich

# ── Demo Mode ───────────────────────────────────────────────────────────────────
# Set to "true" to enable demo-specific behavior (preseeded data, relaxed auth).
# DEMO_MODE=true

# ── CORS Origins ────────────────────────────────────────────────────────────────
# Default (hardcoded in main.py, api.py): * (wildcard)
# Restrict in production:
# CORS_ORIGINS=https://your-frontend.example.com

# ── Session Secret ──────────────────────────────────────────────────────────────
# Used for signing session cookies once real auth is implemented.
# SESSION_SECRET=your-random-secret-here
